<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background1"
    tools:context=".Delivery">

    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginTop="-5dp"
        android:background="@drawable/poly"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <TextView
        android:id="@+id/ID"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:text="DELIVERY"
        android:textColor="@android:color/black"
        android:textSize="23sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/view"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/view"
        app:layout_constraintVertical_bias="0.294" />

    <ImageView
        android:id="@+id/appLogo"
        android:layout_width="56dp"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:src="@drawable/logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view" />


    <LinearLayout
        android:id="@+id/customize_frame"
        android:layout_width="266dp"
        android:layout_height="134dp"
        android:layout_centerHorizontal="true"
        android:background="#d3d3d3"
        android:gravity="center"
        tools:layout_editor_absoluteX="72dp"
        tools:layout_editor_absoluteY="217dp">

        <TextView
            android:id="@+id/customize_frame_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CUSTOMIZE FRAME"
            android:textColor="#000000"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/details"
        android:layout_width="381dp"
        android:layout_height="408dp"
        android:layout_below="@id/customize_frame"
        android:orientation="vertical"
        android:paddingTop="20dp"
        tools:layout_editor_absoluteX="30dp"
        tools:layout_editor_absoluteY="363dp">


        <!-- App Logo -->

        <!-- Name Field -->

        <TextView
            android:id="@+id/details_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="DETAILS:"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="51dp"
            android:text="➤Phn number                        :"
            android:textColor="#000000"
            android:textSize="20sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="57dp"
            android:text="➤ Alternative phn number   :"
            android:textColor="#000000"
            android:textSize="20sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="43dp"
            android:text="➤Adress                                 :"
            android:textColor="#000000"
            android:textSize="20sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="➤ Landmark                          :"
            android:textColor="#000000"
            android:textSize="20sp" />

    </FrameLayout>

    <TextView
        android:id="@+id/details_title"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="MODE OF PAYMENT:"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="30dp"
        tools:layout_editor_absoluteY="657dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:text="Back"
            android:textAllCaps="false"
            android:background="@drawable/btn_bgpurple"
            android:textColor="@android:color/white" />


        <androidx.appcompat.widget.AppCompatButton
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:text="Next"
            android:textAllCaps="false"
            android:background="@drawable/btn_bgpurple"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <ImageView
        android:id="@+id/appLogo"
        android:layout_width="306dp"
        android:layout_height="70dp"
        android:src="@drawable/scanner"
        tools:ignore="DuplicateIds"
        tools:layout_editor_absoluteX="83dp"
        tools:layout_editor_absoluteY="738dp" />

    <ImageView
        android:id="@+id/appLogo"
        android:layout_width="110dp"
        android:layout_height="80dp"
        android:src="@drawable/gpay"
        tools:layout_editor_absoluteX="29dp"
        tools:layout_editor_absoluteY="732dp" />


</androidx.constraintlayout.widget.ConstraintLayout>


